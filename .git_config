[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
[remote "origin"]
	url = git@github.com:larryw3i/MinimalInternetSpeedMeter.git
    url = git@ssh.gitlab.gnome.org:larryw3i/MinimalInternetSpeedMeter.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "master"]
	remote = origin
	merge = refs/heads/master
