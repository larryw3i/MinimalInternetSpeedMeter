[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
[remote "origin"]
    url = git@gitee.com:larryw3i/CrazyInternetSpeedMeter.git
	url = git@github.com:larryw3i/CrazyInternetSpeedMeter.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "master"]
	remote = origin
	merge = refs/heads/master
